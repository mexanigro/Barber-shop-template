{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:en": "cross-env VITE_UI_LANGUAGE=en tsx server.ts",
    "dev:he": "cross-env VITE_UI_LANGUAGE=he tsx server.ts",
    "dev:tattoo:en": "cross-env VITE_ACTIVE_NICHE=tattoo VITE_UI_LANGUAGE=en tsx server.ts",
    "dev:tattoo:he": "cross-env VITE_ACTIVE_NICHE=tattoo VITE_UI_LANGUAGE=he tsx server.ts",
    "build": "vite build",
    "vercel-build": "tsc --project tsconfig.server.json && vite build",
    "build:en": "cross-env VITE_UI_LANGUAGE=en vite build",
    "build:he": "cross-env VITE_UI_LANGUAGE=he vite build",
    "verify:locales": "npm run lint && npm run build:he && npm run build:en",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "a11y": "node scripts/a11y-check.mjs",
    "a11y:he": "node scripts/a11y-check.mjs http://localhost:3000",
    "firebase:login": "npx -y firebase-tools@latest login",
    "firebase:use": "npx -y firebase-tools@latest use",
    "firebase:use:add": "npx -y firebase-tools@latest use --add",
    "firebase:deploy:firestore": "npx -y firebase-tools@latest deploy --only firestore",
    "firebase:deploy:rules": "npm run firebase:deploy:firestore",
    "functions:install": "npm --prefix functions install",
    "functions:build": "npm --prefix functions run build",
    "functions:deploy": "npm --prefix functions run deploy"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "resend": "^6.12.0",
    "serverless-http": "^3.2.0",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
