# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Master Template Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values for your client deployment.
#   cp .env.example .env
#
# Keys marked [REQUIRED] will disable a feature if left blank.
# Keys marked [OPTIONAL] have safe fallback behaviour when empty.
#
# ⚠  Never commit your real `.env` file. It is listed in `.gitignore`.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Application URL ─────────────────────────────────────────────────────────
# [OPTIONAL] Full URL where the app is hosted, including protocol.
# Used for Stripe redirect URLs and self-referential links.
# Defaults to http://localhost:3000 in development.
APP_URL=https://your-client-domain.com

# ─── Tenant identity (multi-tenant required) ─────────────────────────────────
# Canonical tenant id for this deployment (required).
# For compatibility across template stacks:
# - Vite client code reads VITE_CLIENT_ID
# - Server guard accepts NEXT_PUBLIC_CLIENT_ID or VITE_CLIENT_ID
NEXT_PUBLIC_CLIENT_ID=client_barber_01
VITE_CLIENT_ID=client_barber_01

# ─── Firestore config/{clientId} overlay ───────────────────────────────────────
# If config/{clientId} has no business.type, or business.type differs from the
# preset in this build (VITE_ACTIVE_NICHE / env.activeNiche), only infrastructure fields are merged
# from Firestore (features, payment, notifications, adminEmail, splash) — never
# brand/hero/services/staff, so barber exports cannot clobber another niche.
# Set to true to skip even that partial merge (preset-only).
# VITE_DISABLE_FIRESTORE_SITE_OVERRIDE=true

# ─── API Hardening (optional, recommended) ───────────────────────────────────
# Max requests per IP per route within the window (in milliseconds).
# API_RATE_LIMIT_WINDOW_MS=60000
# API_RATE_LIMIT_MAX=60


# ─── Niche + UI language (build-time) — set on Vercel per deployment ─────────
# Niche preset: barberia | estetica | abogado | tattoo | nails (default: barberia)
# VITE_ACTIVE_NICHE=tattoo
#
# Shell UI (nav, buttons, aria): `en` (default) or `he` for Hebrew + RTL layout.
# One deployment = one language — set at build time, then rebuild/redeploy.
# VITE_UI_LANGUAGE=en
# VITE_UI_LANGUAGE=he


# ─── AI Service (Google Gemini) ──────────────────────────────────────────────
# [REQUIRED for AI chat & style consultation features]
# Get your key at: https://aistudio.google.com/app/apikey
# If left empty, AI routes return HTTP 503 and the chatbot shows a friendly
# "service unavailable" message. The rest of the app works normally.
GEMINI_API_KEY=


# ─── Stripe Payments ─────────────────────────────────────────────────────────
# [REQUIRED for online payments]
# Get these from: https://dashboard.stripe.com/developers → API keys
#
# Secret key (server-only, never expose to the client):
STRIPE_SECRET_KEY=
#
# Publishable key (safe for the frontend, prefixed with VITE_ for Vite):
VITE_STRIPE_PUBLISHABLE_KEY=
#
# Webhook signing secret — used to verify Stripe events.
# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# If left empty, the /api/webhook endpoint returns HTTP 503.
STRIPE_WEBHOOK_SECRET=

# Optional: select payment provider strategy for tenant operations metadata.
# Supported architecture targets: stripe, meshulam, yaadpay, authorize_net, square, other
# PAYMENT_PROVIDER=stripe
PAYMENT_PROVIDER=stripe

# Bootstrap admin emails allowed to assign Firebase custom claims through Cloud Function.
# Comma-separated list.
ADMIN_BOOTSTRAP_EMAILS=security-admin@yourdomain.com


# ─── Email Notifications (Resend) ────────────────────────────────────────────
# [REQUIRED to send email notifications]
# Get your key at: https://resend.com → API Keys
# If left empty, notifications are logged to the server console instead of
# being emailed. No errors are thrown.
EMAIL_PROVIDER_API_KEY=
#
# The "from" address shown on outgoing emails.
# Must match a verified domain in your Resend account.
# Defaults to Resend's sandbox address when empty (only works for your own inbox).
EMAIL_FROM_ADDRESS=notifications@yourdomain.com


# ─── Notification Recipients ─────────────────────────────────────────────────
# [REQUIRED for email delivery]
# The primary email address that receives all business notifications.
BUSINESS_OWNER_EMAIL=owner@example.com
#
# [OPTIONAL] Override recipients per notification type.
# Falls back to BUSINESS_OWNER_EMAIL when left empty.
BOOKING_NOTIFICATION_EMAIL=
CONTACT_NOTIFICATION_EMAIL=


# ─── Admin Panel Access ───────────────────────────────────────────────────────
# [REQUIRED to access the admin dashboard]
# The Google account email authorized to log in to the admin panel.
# Only one email is supported per deployment.
VITE_ADMIN_EMAIL=admin@yourdomain.com


# ─── Firebase (Database & Authentication) ────────────────────────────────────
# Recommended: set Firebase Web SDK config via env vars per Vercel project
# (lets the same repo target US/IL Firebase projects without cloning).
# Fallback: if env vars are missing, app reads `firebase-applet-config.json`.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Named Firestore DB id (NOT "(default)" GCP id). Template fallback: "default". Use "nichos-us-prod" for US-region DB when applicable.
VITE_FIREBASE_DATABASE_ID=
