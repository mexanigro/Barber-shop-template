{
  "name": "barber-template-functions",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf lib",
    "deploy": "npm run build && npx -y firebase-tools@latest deploy --only functions",
    "serve": "npm run build && npx -y firebase-tools@latest emulators:start --only functions",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.0.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}
